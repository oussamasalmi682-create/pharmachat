# ── MongoDB ────────────────────────────────────────────────────────────────────
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pharmachat"

# ── Twilio WhatsApp Sandbox ────────────────────────────────────────────────────
# Depuis : https://console.twilio.com > Account Info
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Numéro Twilio Sandbox WhatsApp (toujours ce numéro en sandbox)
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ── Webhook public (ngrok en développement) ────────────────────────────────────
# Lancer : ngrok http 3000
# Puis copier l'URL ici ET dans Twilio Console > Sandbox Settings > "When a message comes in"
TWILIO_WEBHOOK_URL="https://xxxx-xxxx-xxxx.ngrok-free.app/api/webhook"
